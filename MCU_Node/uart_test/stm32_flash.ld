MEMORY
{
    FLASH (rx) : ORIGIN = 0x08000000, LENGTH = 512K
    RAM (rwx)  : ORIGIN = 0x20000000, LENGTH = 128K
}

SECTIONS
{
    .text : {
        LONG(0x20020000); /* Initial Stack Pointer (Top of RAM) */
        LONG(main + 1);   /* Reset Vector (+1 for Thumb mode) */
        *(.text)
    } > FLASH
}
